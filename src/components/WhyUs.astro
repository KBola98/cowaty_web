---
const differentiators = [
  {
    number: '01',
    title: 'Strategy First',
    description: 'Every engagement starts with a clear growth strategy. We map channels, audiences, and goals before a single pound is spent. No spray-and-pray.',
  },
  {
    number: '02',
    title: 'Speed to Lead',
    description: 'Slow agencies lose clients money. We onboard in 48 hours, launch campaigns in days, and iterate in real time — not at the next quarterly review.',
  },
  {
    number: '03',
    title: 'Full Funnel Ownership',
    description: 'From first impression to closed deal, we own the whole journey. One team, one P&L view, no finger-pointing between siloed specialists.',
