---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Cowaty — Get in Touch With Our Digital Growth Team"
  description="Reach Cowaty by email or WhatsApp. We're a digital growth agency based in London. No forms, no gatekeeping — just direct access to the team."
  canonicalPath="/contact"
  schemaType="ContactPage"
>
  <section class="page-hero" aria-labelledby="contact-hero-heading">
    <div class="container">
      <p class="section-label">Contact</p>
      <h1 id="contact-hero-heading">Talk to Cowaty</h1>
      <p>
        No forms. No bots. Reach us directly and get a real reply from the team,
        not an automated sequence.
      </p>
    </div>
  </section>

  <section aria-labelledby="contact-options-heading" style="padding-top: 4rem; padding-bottom: 6rem;">
    <div class="container">
      <h2 id="contact-options-heading" class="visually-hidden">Contact options</h2>

      <div class="contact-cards">
        <article class="contact-card">
          <div class="contact-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.75" fill="none"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" stroke="currentColor" stroke-width="1.75" fill="none"/>
            </svg>
          </div>
          <h3>Email</h3>
          <p>For project enquiries, proposals, or anything else.</p>
          <p style="margin-top: 0.75rem;">
            <a href="mailto:hello@cowaty.com" aria-label="Send an email to hello@cowaty.com">
              hello@cowaty.com
            </a>
          </p>
        </article>

        <article class="contact-card">
          <div class="contact-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.1-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z" stroke="currentColor" stroke-width="1.75" fill="none"/>
            </svg>
          </div>
          <h3>WhatsApp</h3>
          <p>Prefer a faster conversation? Message us directly on WhatsApp.</p>
          <p style="margin-top: 0.75rem;">
            <a
              href="https://wa.me/94787460322"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Message Cowaty on WhatsApp (opens in new tab)"
            >
              Start a WhatsApp chat
            </a>
          </p>
        </article>

        <article class="contact-card">
          <div class="contact-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z" stroke="currentColor" stroke-width="1.75" fill="none"/>
              <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.75" fill="none"/>
            </svg>
          </div>
          <h3>Office</h3>
          <address>
            <p>
              71-75 Shelton Street<br />
              Covent Garden<br />
              London, WC2H 9JQ<br />
              United Kingdom
            </p>
          </address>
        </article>
      </div>

      <div class="contact-note" role="note">
        <p>
          <strong>Careers enquiries:</strong> We're not always hiring, but we're always open to great people.
          Send your CV and a short note to
          <a href="mailto:careers@cowaty.com" aria-label="Send careers enquiry to careers@cowaty.com">careers@cowaty.com</a>
          or
          <a href="https://wa.me/94787460322" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp careers enquiry (opens in new tab)">WhatsApp us</a>.
          See the <a href="/careers">Careers page</a> for more details.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
